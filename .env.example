# Copy to .env and fill in real values.
# Never commit .env to git.

# Postgres connection (matches docker-compose defaults)
DATABASE_URL=postgres://crimelens:crimelens@localhost:5432/crimelens

# 32+ random bytes, used to HMAC-sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# Public base URL (no trailing slash)
BASE_URL=http://localhost:3000

# Server port
PORT=3000

# Email mode: "console" prints magic links to stdout; "resend" sends real email.
MAIL_MODE=console

# Required only when MAIL_MODE=resend
# RESEND_API_KEY=re_...
